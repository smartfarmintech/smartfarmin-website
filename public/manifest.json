{
  "name": "SmartFarmin - Agricultural Technology Platform",
  "short_name": "SmartFarmin",
  "description": "Complete agricultural management platform with machinery booking, drone services, AI crop analysis, and marketplace",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#2d8659",
  "background_color": "#ffffff",
  "categories": ["agriculture", "productivity"],
  "screenshots": [
    {
      "src": "/screenshots/farm-dashboard-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/screenshots/farm-dashboard-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/screenshots/farm-dashboard-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "View Bookings",
      "short_name": "Bookings",
      "description": "View and manage machinery bookings",
      "url": "/farmer/bookings",
      "icons": [
        {
          "src": "/icon-booking-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Drone Missions",
      "short_name": "Drones",
      "description": "Schedule and monitor drone missions",
      "url": "/farmer/drone-missions",
      "icons": [
        {
          "src": "/icon-drone-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "AI Crop Doctor",
      "short_name": "AI Doctor",
      "description": "Analyze crop health with AI",
      "url": "/farmer/ai-reports",
      "icons": [
        {
          "src": "/icon-ai-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Marketplace",
      "short_name": "Market",
      "description": "Buy and sell agricultural products",
      "url": "/farmer/marketplace",
      "icons": [
        {
          "src": "/icon-marketplace-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/png", "image/jpeg", "image/webp"]
        }
      ]
    }
  },
  "prefer_related_applications": false,
  "related_applications": []
}
